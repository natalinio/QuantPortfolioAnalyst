# Azure AI Foundry Endpoints and API Keys

# Pro Model: Claude (Opus / Sonnet)
# Note: Use standard Chat Completions deployment endpoint (ending in /chat/completions), NOT Responses API endpoint (/responses)
AZURE_FOUNDRY_ENDPOINT_PRO=your_pro_endpoint_here
AZURE_FOUNDRY_API_KEY_PRO=your_pro_key_here
AZURE_FOUNDRY_MODEL_PRO=gpt-5.4

# Mini Model: GPT-4.1-mini
AZURE_FOUNDRY_ENDPOINT_MINI=your_mini_endpoint_here
AZURE_FOUNDRY_API_KEY_MINI=your_mini_key_here
AZURE_FOUNDRY_MODEL_MINI=gpt-4.1-mini
AZURE_FOUNDRY_API_VERSION_MINI=2025-01-01-preview

# Blackboard Configuration
DATABASE_PATH=data/qpa_blackboard.db
DEFAULT_BASE_CURRENCY=EUR
LOG_LEVEL=INFO

# FRED API Configuration
FRED_API_KEY=your_fred_key_here

